{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/skills/project-memory-manager/scripts/cleanup-project-temp-files.py\" --execute --quiet || python \"${CLAUDE_PROJECT_DIR:-.}/.claude/skills/project-memory-manager/scripts/cleanup-project-temp-files.py\" --execute --quiet"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/auto-sync-project-card.py\" || python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/auto-sync-project-card.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check-project-memory-drift.py\" || python \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/check-project-memory-drift.py\""
          }
        ]
      }
    ]
  }
}
